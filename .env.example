APP_NAME="Slowloris Lab"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=slowloris_lab
DB_USERNAME=slowloris
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"

# ===== UPLOAD =====
UPLOAD_MAX_SIZE_MB=256
UPLOAD_ALLOWED_ACQUISITION="pcap,pcapng,csv,json"
UPLOAD_ALLOWED_VALIDATION="json,log,csv,txt"

# ===== AI =====
AI_USE_SIMULATION=false
# Provider AI ditambahkan manual lewat dashboard: Pengaturan API.
